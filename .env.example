# ============================================================
# REQUIRED: Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# REQUIRED: Admin Credentials (for admin dashboard login)
# Generate a strong password and keep it secure!
# ============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here_min_12_chars

# ============================================================
# REQUIRED: JWT Secret for token signing
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters, 64+ recommended
# ============================================================
ADMIN_JWT_SECRET=your_very_long_random_secret_here_at_least_64_chars

# LEGACY: Password salt (kept for backward compatibility with old password hashes)
# New passwords use bcrypt. This is only for verifying old SHA256 hashes.
PASSWORD_SALT=your_random_password_salt_here

# ============================================================
# SECURITY: Coach Registration Approval
# Set to "true" to require admin approval before coaches can access the system
# RECOMMENDED: true for production
# ============================================================
COACH_APPROVAL_REQUIRED=true

# ============================================================
# REQUIRED: Storage Configuration
# ============================================================
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=gym-photos

# ============================================================
# OPTIONAL: Gym Contact Info
# ============================================================
NEXT_PUBLIC_GYM_WHATSAPP_NUMBER=201009987771

# ============================================================
# REQUIRED: Gemini API Key for AI features
# Get from: https://makersuite.google.com/app/apikey
# ============================================================
GEMINI_API_KEY=your_google_gemini_api_key_here

# ============================================================
# PRODUCTION REQUIRED: Upstash Redis for Rate Limiting
# Without this, rate limiting won't work correctly on Vercel
# Sign up at: https://upstash.com/ (has a generous free tier)
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ============================================================
# PRODUCTION REQUIRED: Vercel Environment
# This enables production-specific optimizations
# ============================================================
VERCEL_ENV=production

# ============================================================
# SECURITY HEADERS (Optional but recommended)
# These are automatically set by next.config.js
# Only change if you know what you're doing
# ============================================================
# NEXT_PUBLIC_APP_URL=https://your-domain.com
